N2YO_API_KEY=your_key_here
OBSERVER_LAT=41.548
OBSERVER_LNG=2.105
OBSERVER_ALT_M=190
OBSERVER_NAME=Sabadell

# ── LLM Backend ───────────────────────────────────────────────────────────────
# Options: ollama | ik_llama | llamacpp | onnx
#
# Quick start for CPU (no GPU needed):
#   ./scripts/setup_cpu_llm.sh qwen3-4b   # downloads model + sets this file
#
# ── Ollama (default, easiest) ────────────────────────────────────────────────
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── ik_llama.cpp (fastest GPU+CPU hybrid) ────────────────────────────────────
#LLM_BACKEND=ik_llama
#IK_LLAMA_BASE_URL=http://localhost:8080
#IK_LLAMA_MODEL=ik

# ── llamacpp embedded (CPU-only, GGUF, no external process) ──────────────────
# Run: ./scripts/setup_cpu_llm.sh qwen3-4b
#LLM_BACKEND=llamacpp
#LLAMACPP_MODEL_PATH=./models/qwen3-4b-q4_k_m.gguf
#LLAMACPP_N_CTX=32768
#LLAMACPP_N_THREADS=0    # 0 = auto (uses cpu_count - 1)

# ── ONNX embedded (Phi-4-mini INT4, fastest CPU option) ──────────────────────
# Run: ./scripts/setup_cpu_llm.sh phi4mini-onnx
#LLM_BACKEND=onnx
#ONNX_MODEL_PATH=./models/phi4mini-onnx/cpu-int4-rtn-block-32

# ── CPU Model profiles (Pareto frontier) ─────────────────────────────────────
# Profile                    Backend    RAM    Speed     Notes
# phi4mini-onnx              onnx       2.5G   ~20 tok/s Microsoft Phi-4-mini INT4
# qwen3-1.7b                 llamacpp   1.5G   ~18 tok/s Ultra-fast, thinking mode
# qwen3-4b                   llamacpp   2.8G   ~10 tok/s Balanced [RECOMMENDED]
# astrosage-8b               llamacpp   5.0G    ~6 tok/s Astronomy specialist (GPT-4o level)
# qwen3-30b-moe              llamacpp   8.5G    ~8 tok/s MoE: 30B quality at 3B speed
# qwen3-30b-moe-abliterated  llamacpp   8.5G    ~8 tok/s Same, uncensored (huihui-ai)
# qwen3-8b                   llamacpp   5.0G   ~5.5 tok/s Dense 8B, thinking mode
#MODEL_PROFILE=qwen3-4b   # if set, overrides the model path above

USE_VOICE=false
